{
  "name": "interleave",
  "version": "0.5.0",
  "private": true,
  "description": "Interleave — a desktop-first, local-first incremental reading application.",
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=22.13.1 <23",
    "pnpm": ">=9.12.1 <10"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.12",
      "electron-builder-squirrel-windows": "^26.15.0",
      "tar": "^7.5.15"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @interleave/desktop dev",
    "dev:renderer": "pnpm --filter @interleave/web dev",
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "node scripts/bench.mjs",
    "bench:gate": "vitest run --config packages/local-db/vitest.bench-gate.config.ts",
    "bench:table": "vitest bench --run packages/local-db/bench/scale.bench.ts",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "e2e": "playwright test",
    "db:generate": "pnpm --filter @interleave/db db:generate",
    "db:migrate": "pnpm --filter @interleave/db db:migrate",
    "db:reset:dev": "pnpm --filter @interleave/db db:reset:dev",
    "seed": "tsx scripts/seed-dev.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@interleave/db": "workspace:*",
    "@interleave/local-db": "workspace:*",
    "@interleave/testing": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.6",
    "turbo": "^2.5.5",
    "typescript": "^5.7.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
