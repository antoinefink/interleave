# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.tsbuild/
out/

# …but the desktop electron-builder buildResources dir holds SOURCE inputs (the app
# icon), not build output — keep it tracked.
!apps/desktop/build/
!apps/desktop/build/**

# Electron desktop: bundled main/preload + the vendored, Electron-ABI native copy
# of better-sqlite3 (rebuilt by apps/desktop/scripts/vendor-native.mjs)
apps/desktop/dist/
apps/desktop/native/

# Electron desktop: electron-builder packaging output (the .app/.dmg installer; T050)
apps/desktop/release/

# TypeScript incremental / project-reference build info
*.tsbuildinfo

# Turborepo
.turbo/

# Test / coverage artifacts
coverage/
.vitest/

# Playwright (added in T002+)
test-results/
playwright-report/
playwright/.cache/
blob-report/

# Vite (added in T003+)
.vite/

# Local dev SQLite database (T006); generated migrations are committed, the DB is not
packages/db/.dev/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# On-device embedding model cache (T087): Transformers.js downloads the real
# EmbeddingGemma ONNX model + tokenizer into its local cache (or
# `INTERLEAVE_MODEL_DIR`) on first run — a transient, re-downloadable artifact, never committed.
local_cache/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example

# Local Codex/agent worktree config
.codex/
.claude/worktrees/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# macOS release signing — kept local/private (personal Apple + 1Password details).
# The signing CODE (electron-builder.config.cjs, entitlements, scripts) is committed;
# only the maintainer-specific runbook, credentials env, and plan stay out of the repo.
apps/desktop/release.op-env
.claude/skills/release-macos/
docs/plans/2026-06-09-macos-signing-notarization-plan.md
