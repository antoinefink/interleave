# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.tsbuild/
out/

# …but the desktop electron-builder buildResources dir holds SOURCE inputs (the app
# icon), not build output — keep it tracked.
!apps/desktop/build/
!apps/desktop/build/**

# Electron desktop: bundled main/preload + the vendored, Electron-ABI native copy
# of better-sqlite3 (rebuilt by apps/desktop/scripts/vendor-native.mjs)
apps/desktop/dist/
apps/desktop/native/

# Electron desktop: electron-builder packaging output (the .app/.dmg installer; T050)
apps/desktop/release/

# TypeScript incremental / project-reference build info
*.tsbuildinfo

# Turborepo
.turbo/

# Test / coverage artifacts
coverage/
.vitest/

# Playwright (added in T002+)
test-results/
playwright-report/
playwright/.cache/
blob-report/

# Vite (added in T003+)
.vite/

# Local dev SQLite database (T006); generated migrations are committed, the DB is not
packages/db/.dev/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# On-device embedding model cache (T087): `fastembed` downloads the real
# all-MiniLM-L6-v2 ONNX model + tokenizer into its default `local_cache/` (or
# `INTERLEAVE_MODEL_DIR`) on first run — a transient, re-downloadable artifact, never committed.
local_cache/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Environment
.env
.env.*
!.env.example

# Local Codex config
.codex/

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
