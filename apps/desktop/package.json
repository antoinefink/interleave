{
  "name": "@interleave/desktop",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Interleave Electron desktop shell — main process, preload bridge, native SQLite, IPC.",
  "main": "dist/main.cjs",
  "scripts": {
    "build:bundle": "node build.mjs",
    "build": "node build.mjs",
    "dev": "node scripts/dev.mjs",
    "start": "node build.mjs && electron .",
    "test": "vitest run",
    "lint": "echo \"@interleave/desktop: linted at the workspace root via Biome\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "rebuild:native": "node scripts/vendor-native.mjs",
    "postinstall": "node scripts/vendor-native.mjs",
    "dist": "node scripts/dist.mjs",
    "dist:pack": "electron-builder --mac --config electron-builder.config.cjs",
    "dist:release": "op run --env-file=release.op-env -- node scripts/dist.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "fastembed": "^2.1.0",
    "fflate": "^0.8.2",
    "tesseract.js": "^6.0.1",
    "tesseract.js-core": "^6.1.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@interleave/capture-contract": "workspace:*",
    "@interleave/core": "workspace:*",
    "@interleave/db": "workspace:*",
    "@interleave/importers": "workspace:*",
    "@interleave/local-db": "workspace:*",
    "@interleave/scheduler": "workspace:*",
    "@interleave/testing": "workspace:*",
    "@interleave/web": "workspace:*",
    "@tesseract.js-data/eng": "^1.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/yazl": "^2.4.6",
    "drizzle-orm": "^0.45.2",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.0",
    "electron-builder-squirrel-windows": "^26.15.0",
    "esbuild": "^0.28.1",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  }
}
