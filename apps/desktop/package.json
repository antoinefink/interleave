{
  "name": "@interleave/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Interleave Electron desktop shell — main process, preload bridge, native SQLite, IPC.",
  "main": "dist/main.cjs",
  "scripts": {
    "build:bundle": "node build.mjs",
    "build": "node build.mjs",
    "dev": "node scripts/dev.mjs",
    "start": "node build.mjs && electron .",
    "test": "vitest run",
    "lint": "echo \"@interleave/desktop: linted at the workspace root via Biome\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "rebuild:native": "node scripts/vendor-native.mjs",
    "postinstall": "node scripts/vendor-native.mjs"
  },
  "dependencies": {
    "@interleave/core": "workspace:*",
    "@interleave/db": "workspace:*",
    "@interleave/local-db": "workspace:*",
    "@interleave/scheduler": "workspace:*",
    "@interleave/testing": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/yazl": "^2.4.6",
    "electron": "^38.8.6",
    "esbuild": "^0.25.12"
  }
}
