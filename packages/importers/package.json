{
  "name": "@interleave/importers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "echo \"@interleave/importers: no dev step\"",
    "build": "echo \"@interleave/importers: no build step\"",
    "test": "vitest run",
    "lint": "echo \"@interleave/importers: linted from repo root via biome\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@interleave/core": "workspace:*",
    "@interleave/editor": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "fast-xml-parser": "^4.5.0",
    "fflate": "^0.8.2",
    "linkedom": "^0.18.12",
    "markdown-it": "^14.2.0",
    "papaparse": "^5.4.1",
    "pdfjs-dist": "^4.10.38",
    "sanitize-html": "^2.17.4",
    "subsrt-ts": "^2.1.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/papaparse": "^5.3.15",
    "@types/sanitize-html": "^2.16.1"
  }
}
