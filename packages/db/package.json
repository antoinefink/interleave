{
  "name": "@interleave/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "echo \"@interleave/db: no dev step\"",
    "build": "echo \"@interleave/db: no build step\"",
    "test": "vitest run",
    "lint": "echo \"@interleave/db: linted from repo root via biome\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset:dev": "tsx scripts/reset-dev.ts"
  },
  "dependencies": {
    "@interleave/core": "workspace:^",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6"
  }
}
