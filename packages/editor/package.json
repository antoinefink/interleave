{
  "name": "@interleave/editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./block-id": {
      "types": "./src/block-id.ts",
      "default": "./src/block-id.ts"
    },
    "./block-ids": {
      "types": "./src/block-ids.ts",
      "default": "./src/block-ids.ts"
    }
  },
  "scripts": {
    "dev": "echo \"@interleave/editor: no dev step\"",
    "build": "echo \"@interleave/editor: no build step\"",
    "test": "vitest run",
    "lint": "echo \"@interleave/editor: linted from repo root via biome\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@interleave/core": "workspace:*",
    "@shikijs/core": "4.1.0",
    "@shikijs/langs": "4.1.0",
    "@shikijs/themes": "4.1.0",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-code-block": "3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "katex": "^0.17.0",
    "shiki": "^4.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
